{
  "source": "../../Binary_Tree/Q5_E_BT.c",
  "notes": "Extended cases for mirroring a binary tree.",
  "cases": [
    {
      "name": "sample_mirror_tree",
      "input": "1\n4\n5\n2\na\n6\na\na\n3\n1\na\na\na\na\n2\n0\n",
      "expect_contains_all": [
        "The resulting binary tree is: 5 6 4 3 2 1",
        "Mirror binary tree is: 1 2 3 4 6 5"
      ],
      "normalize_whitespace": true
    },
    {
      "name": "single_node_mirror_is_unchanged",
      "input": "1\n9\na\na\n2\n0\n",
      "expect_contains_all": [
        "The resulting binary tree is: 9",
        "Mirror binary tree is: 9"
      ],
      "normalize_whitespace": true
    },
    {
      "name": "two_child_tree_swaps_sides",
      "input": "1\n1\n2\n3\na\na\na\na\n2\n0\n",
      "expect_contains_all": [
        "The resulting binary tree is: 2 1 3",
        "Mirror binary tree is: 3 1 2"
      ],
      "normalize_whitespace": true
    }
  ]
}
