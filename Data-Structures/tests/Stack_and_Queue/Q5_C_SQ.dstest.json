{
  "source": "../../Stack_and_Queue/Q5_C_SQ.c",
  "notes": "Extended cases for recursive queue reversal.",
  "cases": [
    {
      "name": "sample_recursive_reverse_queue",
      "input": "1\n1\n1\n2\n1\n3\n1\n4\n1\n5\n2\n0\n",
      "expect_contains_all": [
        "The resulting reversed queue is: 5 4 3 2 1"
      ],
      "normalize_whitespace": true
    },
    {
      "name": "even_length_queue_reversed_recursively",
      "input": "1\n10\n1\n20\n1\n30\n1\n40\n2\n0\n",
      "expect_contains_all": [
        "The resulting reversed queue is: 40 30 20 10"
      ],
      "normalize_whitespace": true
    },
    {
      "name": "single_item_queue_stays_same_recursively",
      "input": "1\n99\n2\n0\n",
      "expect_contains_all": [
        "The resulting reversed queue is: 99"
      ],
      "normalize_whitespace": true
    }
  ]
}
