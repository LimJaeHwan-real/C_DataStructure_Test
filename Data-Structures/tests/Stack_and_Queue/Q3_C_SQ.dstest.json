{
  "source": "../../Stack_and_Queue/Q3_C_SQ.c",
  "notes": "Extended cases for checking whether a stack is pairwise consecutive.",
  "cases": [
    {
      "name": "sample_pairwise_consecutive_true",
      "input": "1\n4\n1\n5\n1\n10\n1\n11\n1\n15\n1\n16\n2\n0\n",
      "expect_contains_all": [
        "The stack is pairwise consecutive."
      ],
      "normalize_whitespace": true
    },
    {
      "name": "non_consecutive_pair_detected",
      "input": "1\n4\n1\n6\n1\n10\n1\n11\n2\n0\n",
      "expect_contains_all": [
        "The stack is not pairwise consecutive."
      ],
      "normalize_whitespace": true
    },
    {
      "name": "single_pair_is_consecutive",
      "input": "1\n8\n1\n9\n2\n0\n",
      "expect_contains_all": [
        "The stack is pairwise consecutive."
      ],
      "normalize_whitespace": true
    }
  ]
}
