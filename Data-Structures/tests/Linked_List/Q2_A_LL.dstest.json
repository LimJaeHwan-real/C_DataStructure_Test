    },
    {
      "name": "one_element_each_list",
      "input": "1\n10\n2\n20\n3\n0\n",
      "expect_contains_all": [
        "The resulting linked list 1: 10 20",
        "The resulting linked list 2: Empty"
      ],
      "normalize_whitespace": true
    },
    {
      "name": "second_list_empty_leaves_first_unchanged",
      "input": "1\n8\n1\n9\n1\n10\n3\n0\n",
